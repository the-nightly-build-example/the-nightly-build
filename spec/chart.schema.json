{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "nb-chart",
  "type": "object",
  "required": ["type", "labels", "series"],
  "properties": {
    "type": { "enum": ["line", "bar", "scatter"] },
    "title": { "type": "string" },
    "labels": { "type": "array", "minItems": 1 },
    "series": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "values"],
        "properties": {
          "name": { "type": "string" },
          "values": { "type": "array", "items": { "type": "number" } }
        }
      }
    },
    "y": {
      "type": "object",
      "properties": {
        "scale": { "enum": ["linear", "log"] },
        "label": { "type": "string" }
      }
    }
  }
}
